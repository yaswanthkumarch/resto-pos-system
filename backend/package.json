{
  "name": "@resto/backend",
  "version": "1.0.0",
  "description": "Backend API server for restaurant POS system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:setup": "ts-node src/scripts/setup-db.ts",
    "db:migrate": "ts-node src/scripts/migrate.ts",
    "db:seed": "ts-node src/scripts/seed.ts",
    "db:optimize": "ts-node src/scripts/run-optimization.ts",
    "perf:test": "ts-node src/scripts/performance-test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@resto/shared": "^1.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "joi": "^17.9.2",
    "socket.io": "^4.6.1",
    "redis": "^4.6.5",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.8.2",
    "dotenv": "^16.0.3",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.15.0",
    "node-cron": "^3.0.2",
    "uuid": "^9.0.0",
    "ws": "^8.13.0",
    "node-fetch": "^2.6.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "@types/morgan": "^1.9.4",
    "@types/pg": "^8.10.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.7",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.5",
    "@types/node-fetch": "^2.6.4",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
} 